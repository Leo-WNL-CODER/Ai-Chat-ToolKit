{
  "manifest_version": 3,
  "name": "AI Chat Productivity Toolkit",
  "version": "1.0.0",
  "minimum_chrome_version": "114",
  "description": "Enhance productivity on AI chat platforms by collapsing responses, highlighting text, and more.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://chat.openai.com/*",
    "*://gemini.google.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Chat Toolkit"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://chat.openai.com/*"
      ],
      "css": [
        "content/platforms/chatgpt/chatgpt.css"
      ]
    },
    {
      "matches": [
        "*://gemini.google.com/*"
      ],
      "css": [
        "content/platforms/gemini/gemini.css"
      ]
    },
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://gemini.google.com/*"
      ],
      "js": [
        "content/storage.js",
        "content/platforms/chatgpt/chatgpt.js",
        "content/platforms/gemini/gemini.js",
        "content/highlighter.js",
        "content/toolbar.js",
        "content/main.js"
      ],
      "css": [
        "content/theme.css",
        "content/toolbar.css",
        "content/highlighter.css"
      ],
      "run_at": "document_idle"
    }
  ]
}